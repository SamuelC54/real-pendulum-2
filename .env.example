# Copy to `.env` in the repository root (same folder as package.json).
# See README — loaded automatically by `npm run dev` / `dev:no-kill`.

# --- motor service / @real-pendulum/motor-service (optional) ---
# Absolute path to teknic_motor.dll if not using native/build/Release default.
# TEKNIC_DLL=

# Hub/COM/motion tuning is NOT env-driven — edit TeknicCfg in
# apps/motor-service/native/teknic_motor/teknic_cfg.h and rebuild the DLL.

# --- Ports (optional) ---
# Connect base URL for control-api → motor service (include http://).
# MOTOR_GRPC_URL=http://127.0.0.1:50051
# MOTOR_GRPC_PORT=50051

# --- sensor service / @real-pendulum/sensor-service (Arduino USB serial) ---
# SENSOR_GRPC_URL=http://127.0.0.1:50052
# SENSOR_GRPC_PORT=50052
# Optional default when the web UI does not pass a port. Examples: COM3, /dev/ttyACM0
# SENSOR_SERIAL_PORT=
# SENSOR_SERIAL_BAUD=115200

# --- flash script (npm run flash:sensor-firmware) — Arduino CLI, not Node serial ---
# ARDUINO_FQBN=arduino:avr:uno
# ARDUINO_PORT=COM3

# Optional: absolute path to repo root so control-api can find `scripts/flash-sensor-firmware.mjs`
# when the API is started outside the monorepo folder (browser "Flash firmware" button).
# REPO_ROOT=

# Delay (ms) after disconnecting serial before running Arduino CLI upload (Windows COM release).
# FLASH_AFTER_DISCONNECT_MS=2000
# Extra wait + third upload try when avrdude reports com-state (flash-sensor-firmware.mjs).
# FLASH_UPLOAD_STALL_MS=5000

# --- rail homing (control-api `rail.home` / web “Home rail”) ---
# Uses Teknic Motion.PosnMeasured for rail position; Arduino limits only.
# HOMING_JOG_RPM=60
# HOMING_POLL_MS=50
# HOMING_PHASE_TIMEOUT_MS=120000
# HOMING_MID_POSITION_TOLERANCE=2
# HOMING_APPROACH_POSITION=48
# HOMING_APPROACH_RPM=22
# Legacy aliases: HOMING_MID_TICK_TOLERANCE, HOMING_APPROACH_TICKS
# After mid, Teknic ZeroMeasuredPosition (set 0 to skip).
# HOMING_ZERO_MOTOR_POSITION_AT_MID=1

# CONTROL_API_PORT=4000
# VITE_DEV_PORT=5173
