# Copy to `.env` in the repository root (same folder as package.json).
# See README — loaded automatically by `npm run dev` / `dev:no-kill`.

# --- motor-grpc (optional) ---
# Absolute path to teknic_motor.dll if not using the default next to the package.
# TEKNIC_DLL=

# Hub/COM/motion tuning is NOT env-driven — edit TeknicCfg in
# apps/motor-grpc/native/teknic_motor/teknic_motor.cpp and rebuild the DLL.

# --- Ports (optional) ---
# MOTOR_GRPC_PORT=50051
# CONTROL_API_PORT=4000
# VITE_DEV_PORT=5173
