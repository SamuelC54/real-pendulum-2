<!-- Cart on horizontal rail (slide +X) with pendulum in the X–Z plane (hinge axis +Y).
     q_pendulum = 0: bob hangs toward −Z (straight down). Positive q rotates toward +X. -->
<mujoco model="cart_pendulum">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.004166666666666667" gravity="0 0 -9.80665" integrator="RK4"/>

  <default>
    <joint damping="0.04" armature="0.001"/>
    <geom rgba="0.55 0.55 0.6 1" friction="0.2 0.05 0.001"/>
  </default>

  <worldbody>
    <geom name="rail" type="box" size="2 0.02 0.01" pos="0 0 0" rgba="0.35 0.35 0.4 1" contype="0" conaffinity="0"/>
    <body name="cart" pos="0 0 0.05">
      <!-- Belt: position servo on slide (kp from cartVelocityTrackingPerSec in plant.py). -->
      <joint name="cart_slide" type="slide" axis="1 0 0" damping="0.5" limited="false"/>
      <geom name="cart_geom" type="box" size="0.06 0.04 0.03" mass="0.8"/>
      <body name="pendulum" pos="0 0 0">
        <joint name="pendulum_hinge" type="hinge" axis="0 1 0" pos="0 0 0"/>
        <geom name="rod" type="capsule" fromto="0 0 0 0 0 -0.35" size="0.004" mass="0.12"/>
        <geom name="bob" type="sphere" size="0.03" pos="0 0 -0.35" mass="0.12"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- ctrl = cart position setpoint (m); kp/kv tuned in plant.py from cartVelocityTrackingPerSec -->
    <position name="cart_pos" joint="cart_slide" kp="1200" kv="120"
              ctrllimited="true" ctrlrange="-1.8 1.8"/>
  </actuator>
</mujoco>
