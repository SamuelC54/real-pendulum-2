{
  "name": "@real-pendulum/control-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./router": "./src/router.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "predev": "npm --prefix ../physical-motor-service run build && npm --prefix ../physical-sensor-service run build",
    "prebuild": "npm --prefix ../physical-motor-service run build && npm --prefix ../physical-sensor-service run build",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:tsx": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.0",
    "@connectrpc/connect": "^2.1.0",
    "@connectrpc/connect-node": "^2.1.0",
    "@real-pendulum/app-config": "*",
    "@real-pendulum/controller-service": "*",
    "@real-pendulum/simulation": "*",
    "@real-pendulum/motor-proto": "*",
    "@real-pendulum/physical-motor-service": "*",
    "@real-pendulum/physical-sensor-service": "*",
    "@trpc/server": "^11.1.2",
    "cors": "^2.8.5",
    "superjson": "^2.2.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
